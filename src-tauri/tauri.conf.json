{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cubera",
  "version": "0.1.0",
  "identifier": "com.cubera.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cubera",
        "width": 1120,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Game",
    "shortDescription": "Minecraft launcher for macOS",
    "longDescription": "Cubera is a modern Minecraft launcher for macOS with vanilla, Fabric, Forge, and Modrinth support.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "background": "images/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 160,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 500,
          "y": 190
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
